{
	"name": "nai-long-live",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"preview": "bun run build && wrangler dev",
		"build-only": "vite build",
		"check": "biome check .",
		"format": "biome check --write .",
